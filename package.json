{
	"name": "@ecopages/ecopages",
	"private": true,
	"version": "0.1.105",
	"scripts": {
		"dev:docs": "pnpm --filter @ecopages/docs run dev",
		"build:docs": "pnpm --filter @ecopages/docs run build",
		"start:docs": "pnpm --filter @ecopages/docs run start",
		"preview:docs": "pnpm --filter @ecopages/docs run preview",
		"clean": "clear && pnpx npkill -D -y && rm -rf pnpm-lock.yaml node_modules && pnpm install",
		"format": "prettier --write .",
		"lint": "oxlint . --fix",
		"lint-staged": "lint-staged",
		"jsr:sync-version": "tsx scripts/jsr-sync-version.ts",
		"prerelease": "pnpm run test:all && pnpm run jsr:sync-version",
		"release": "pnpm --filter '*' run release:jsr",
		"bump:patch": "tsx scripts/bump-version.ts patch && pnpm run jsr:sync-version",
		"bump:minor": "tsx scripts/bump-version.ts minor && pnpm run jsr:sync-version",
		"bump:major": "tsx scripts/bump-version.ts major && pnpm run jsr:sync-version",
		"commit": "better-commits",
		"prepare:husky": "husky",
		"test:all": "pnpm run test:vitest && playwright test",
		"test:vitest": "vitest run --project shared-core --project browser",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"typecheck": "pnpm --filter '*' run typecheck"
	},
	"devDependencies": {
		"@biomejs/biome": "2.0.6",
		"@playwright/test": "^1.57.0",
		"@vitest/browser": "^4.0.16",
		"@vitest/browser-playwright": "^4.0.16",
		"better-commits": "^1.18.1",
		"husky": "^9.0.10",
		"lint-staged": "^15.2.2",
		"oxlint": "^1.32.0",
		"playwright": "^1.57.0",
		"prettier": "^3.7.4",
		"tsx": "^4.19.2",
		"typescript": "^5.9.3",
		"vitest": "^4.0.16"
	},
	"module": "src/index.js",
	"repository": "https://github.com/ecopages/ecopages.git",
	"type": "module"
}
