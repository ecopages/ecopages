{
	"name": "@ecopages/ecopages",
	"private": true,
	"version": "0.1.105",
	"scripts": {
		"dev:docs": "bun run --elide-lines 0 --filter @ecopages/docs dev",
		"build:docs": "bun run --filter @ecopages/docs build",
		"start:docs": "bun run --filter @ecopages/docs start",
		"preview:docs": "bun run --filter @ecopages/docs preview",
		"clean": "clear && bunx npkill -D -y && rm -rf bun.lock && bun install",
		"format": "bunx prettier --write .",
		"lint": "bunx oxlint . --fix",
		"lint-staged": "lint-staged",
		"jsr:sync-version": "bun scripts/jsr-sync-version.ts",
		"prerelease": "bun run test:all && bun run jsr:sync-version",
		"release": "bun run --filter '*' release:jsr",
		"bump:patch": "bun run scripts/bump-version.ts patch && bun run jsr:sync-version",
		"bump:minor": "bun run scripts/bump-version.ts minor && bun run jsr:sync-version",
		"bump:major": "bun run scripts/bump-version.ts major && bun run jsr:sync-version",
		"commit": "better-commits",
		"prepare:husky": "husky",
		"test:all": "bun run test:vitest && bunx playwright test",
		"test:vitest": "bunx vitest run --project shared-core --project browser",
		"test:e2e:ui": "bunx playwright test --ui",
		"typecheck": "bun run --elide-lines 0 --filter '*' typecheck"
	},
	"devDependencies": {
		"@biomejs/biome": "2.0.6",
		"@playwright/test": "^1.57.0",
		"@vitest/browser": "^4.0.16",
		"@vitest/browser-playwright": "^4.0.16",
		"better-commits": "^1.18.1",
		"husky": "^9.0.10",
		"lint-staged": "^15.2.2",
		"oxlint": "^1.32.0",
		"playwright": "^1.57.0",
		"prettier": "^3.7.4",
		"vitest": "^4.0.16"
	},
	"module": "src/index.js",
	"repository": "https://github.com/ecopages/ecopages.git",
	"workspaces": [
		"npm/*",
		"packages/*",
		"packages/core/__fixtures__/app",
		"packages/integrations/*",
		"packages/loaders/*",
		"packages/plugins/*",
		"packages/processors/*",
		"playground/*",
		"e2e/fixtures/*",
		"apps/*"
	],
	"type": "module"
}
