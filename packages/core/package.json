{
	"name": "@ecopages/core",
	"version": "0.1.105",
	"description": "Core package for Ecopages",
	"keywords": [
		"ecopages",
		"core",
		"ssg"
	],
	"license": "MIT",
	"main": "./src/index.ts",
	"type": "module",
	"files": [
		"src"
	],
	"sideEffects": false,
	"repository": {
		"type": "git",
		"url": "https://github.com/ecopages/ecopages.git",
		"directory": "packages/core"
	},
	"scripts": {
		"typecheck": "bunx tsc --noEmit",
		"release:jsr": "bunx jsr publish"
	},
	"dependencies": {
		"@ecopages/file-system": "workspace:*",
		"@ecopages/logger": "latest",
		"@ecopages/scripts-injector": "^0.1.3",
		"@worker-tools/html-rewriter": "0.1.0-pre.19",
		"chokidar": "^4.0.3",
		"esbuild": "^0.27.3",
		"ghtml": "^4.0.2",
		"oxc-parser": "^0.110.0",
		"ws": "^8.18.0"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/ws": "^8.5.14",
		"arktype": "^2.1.29",
		"tailwindcss": "^3.4.19",
		"tsx": "^4.20.5",
		"valibot": "^1.2.0",
		"zod": "^4.3.6"
	},
	"exports": {
		".": {
			"browser": "./src/index.browser.ts",
			"import": "./src/index.ts",
			"require": "./src/index.ts",
			"types": "./src/index.ts"
		},
		"./create-app": {
			"types": "./src/create-app.ts",
			"default": "./src/create-app.ts"
		},
		"./route-renderer/integration-renderer": {
			"types": "./src/route-renderer/integration-renderer.ts",
			"default": "./src/route-renderer/integration-renderer.ts"
		},
		"./errors/locals-access-error": {
			"types": "./src/errors/locals-access-error.ts",
			"default": "./src/errors/locals-access-error.ts"
		},
		"./eco": {
			"types": "./src/eco/eco.ts",
			"default": "./src/eco/eco.ts"
		},
		"./declarations": {
			"types": "./src/declarations.d.ts"
		},
		"./env": {
			"types": "./src/env.d.ts"
		},
		"./config-builder": {
			"types": "./src/config/config-builder.ts",
			"default": "./src/config/config-builder.ts"
		},
		"./constants": {
			"types": "./src/constants.ts",
			"default": "./src/constants.ts"
		},
		"./bun": {
			"types": "./src/adapters/bun/index.ts",
			"default": "./src/adapters/bun/index.ts"
		},
		"./bun/create-app": {
			"types": "./src/adapters/bun/create-app.ts",
			"default": "./src/adapters/bun/create-app.ts"
		},
		"./bun/define-api-handler": {
			"types": "./src/adapters/bun/define-api-handler.ts",
			"default": "./src/adapters/bun/define-api-handler.ts"
		},
		"./hmr/hmr-strategy": {
			"types": "./src/hmr/hmr-strategy.ts",
			"default": "./src/hmr/hmr-strategy.ts"
		},
		"./internal-types": {
			"types": "./src/internal-types.ts"
		},
		"./services/asset-processing-service": {
			"types": "./src/services/asset-processing-service/index.ts",
			"default": "./src/services/asset-processing-service/index.ts"
		},
		"./utils/deep-merge": {
			"types": "./src/utils/deep-merge.ts",
			"default": "./src/utils/deep-merge.ts"
		},
		"./utils/ecopages-url-resolver": {
			"types": "./src/utils/ecopages-url-resolver.ts",
			"default": "./src/utils/ecopages-url-resolver.ts"
		},
		"./utils/invariant": {
			"types": "./src/utils/invariant.ts",
			"default": "./src/utils/invariant.ts"
		},
		"./utils/parse-cli-args": {
			"types": "./src/utils/parse-cli-args.ts",
			"default": "./src/utils/parse-cli-args.ts"
		},
		"./plugins/processor": {
			"types": "./src/plugins/processor.ts",
			"default": "./src/plugins/processor.ts"
		},
		"./plugins/integration-plugin": {
			"types": "./src/plugins/integration-plugin.ts",
			"default": "./src/plugins/integration-plugin.ts"
		},
		"./build/build-types": {
			"types": "./src/build/build-types.ts",
			"default": "./src/build/build-types.ts"
		},
		"./build/build-adapter": {
			"types": "./src/build/build-adapter.ts",
			"default": "./src/build/build-adapter.ts"
		},
		"./adapters/bun/client-bridge": {
			"types": "./src/adapters/bun/client-bridge.ts",
			"default": "./src/adapters/bun/client-bridge.ts"
		},
		"./node": {
			"types": "./src/adapters/node/index.ts",
			"default": "./src/adapters/node/index.ts"
		},
		"./node/server-adapter": {
			"types": "./src/adapters/node/server-adapter.ts",
			"default": "./src/adapters/node/server-adapter.ts"
		},
		"./node/create-app": {
			"types": "./src/adapters/node/create-app.ts",
			"default": "./src/adapters/node/create-app.ts"
		},
		"./html": {
			"import": "./src/utils/html.ts",
			"require": "./src/utils/html.ts"
		},
		"./css": {
			"import": "./src/utils/css.ts",
			"require": "./src/utils/css.ts"
		},
		"./hash": {
			"import": "./src/utils/hash.ts",
			"require": "./src/utils/hash.ts"
		},
		"./errors": {
			"types": "./src/errors/index.ts",
			"default": "./src/errors/index.ts"
		},
		"./integrations/ghtml": {
			"types": "./src/integrations/ghtml/ghtml.plugin.ts",
			"default": "./src/integrations/ghtml/ghtml.plugin.ts"
		}
	}
}
