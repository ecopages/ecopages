{
	"name": "@ecopages/ecopages-jsx",
	"version": "0.2.0-alpha.38",
	"description": "JSX integration plugin for Ecopages",
	"keywords": [
		"ecopages",
		"jsx",
		"plugin"
	],
	"license": "MIT",
	"main": "./src/ecopages-jsx.plugin.ts",
	"types": "./src/ecopages-jsx.plugin.ts",
	"type": "module",
	"files": [
		"src"
	],
	"exports": {
		".": {
			"default": "./src/ecopages-jsx.plugin.ts",
			"types": "./src/ecopages-jsx.plugin.ts"
		},
		"./eco-embed": {
			"default": "./src/eco-embed.tsx",
			"types": "./src/eco-embed.tsx"
		}
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/ecopages/ecopages.git",
		"directory": "packages/integrations/ecopages-jsx"
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"release:jsr": "bunx jsr publish"
	},
	"devDependencies": {
		"@kitajs/html": "^4.2.13",
		"@ecopages/core": "workspace:*",
		"@ecopages/testing": "workspace:*",
		"lit": "^3.3.3",
		"react": "^19.2.6",
		"remark-gfm": "^4.0.1"
	},
	"dependencies": {
		"@mdx-js/mdx": "^3.1.1",
		"vfile": "^6.0.3"
	},
	"peerDependencies": {
		"@ecopages/core": "workspace:*",
		"@ecopages/jsx": "0.3.0-alpha.25",
		"@ecopages/radiant": "0.3.0-alpha.25"
	}
}
