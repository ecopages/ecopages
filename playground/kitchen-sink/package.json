{
	"name": "@ecopages/kitchen-sink",
	"private": true,
	"type": "module",
	"scripts": {
		"start": "pnpm run start:bun",
		"dev": "pnpm run dev:bun",
		"build": "pnpm run build:bun",
		"preview": "pnpm run preview:bun",
		"watch:dev": "pnpm run dev:bun",
		"start:bun": "ecopages start --runtime bun",
		"dev:bun": "ecopages dev --runtime bun",
		"build:bun": "ecopages build --runtime bun",
		"preview:bun": "ecopages preview --runtime bun",
		"start:node": "ecopages start --runtime node",
		"dev:node": "ecopages dev --runtime node",
		"build:node": "ecopages build --runtime node",
		"preview:node": "ecopages preview --runtime node",
		"dev:vite": "pnpm run dev:vite:node",
		"dev:vite:node": "ECOPAGES_KITCHEN_SINK_HOST=vite pnpm exec vite dev",
		"dev:vite:bun": "ECOPAGES_KITCHEN_SINK_HOST=vite bunx vite dev",
		"test:e2e": "pnpm run test:e2e:dev && pnpm run test:e2e:preview",
		"test:e2e:dev": "playwright test --config ../../playwright.config.ts --project kitchen-sink-bun-e2e --project kitchen-sink-node-e2e --project kitchen-sink-vite-node-e2e --project kitchen-sink-vite-bun-e2e",
		"test:e2e:preview": "playwright test --config ../../playwright.config.ts --project kitchen-sink-preview-bun-e2e --project kitchen-sink-preview-node-e2e",
		"test:e2e:review": "pnpm run test:e2e:review:dev",
		"test:e2e:review:dev": "playwright test --config ../../playwright.config.ts --project kitchen-sink-bun-review-e2e --project kitchen-sink-node-review-e2e --project kitchen-sink-vite-node-review-e2e --project kitchen-sink-vite-bun-review-e2e"
	},
	"devDependencies": {
		"@ecopages/browser-router": "workspace:*",
		"@ecopages/vite-plugin": "workspace:*",
		"ecopages": "workspace:*",
		"@ecopages/core": "workspace:*",
		"@ecopages/file-system": "workspace:*",
		"@ecopages/image-processor": "workspace:*",
		"@ecopages/kitajs": "workspace:*",
		"@ecopages/lit": "workspace:*",
		"@ecopages/mdx": "workspace:*",
		"@ecopages/postcss-processor": "workspace:*",
		"@ecopages/react": "workspace:*",
		"@ecopages/react-router": "workspace:*",
		"@ecopages/scripts-injector": "^0.1.3",
		"@fontsource-variable/jetbrains-mono": "^5.2.6",
		"@kitajs/html": "^4.2.13",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@tailwindcss/postcss": "^4.0.0",
		"@types/node": "^24.10.1",
		"lit": "^3.3.2",
		"react": "^19",
		"react-dom": "^19",
		"tailwindcss": "^4.0.0",
		"vite": "8.0.4",
		"zod": "^4.3.6"
	},
	"dependencies": {
		"@mdx-js/mdx": "^3.1.1"
	}
}
